# KirinNet Platform — Environment Configuration
# Copy to .env and fill in values.

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kirinnet
DB_USER=kirinnet
DB_PASS=kirinnet

# JWT secret (change in production!)
JWT_SECRET=change-this-to-a-random-string-in-production

# Signature verification (set to 'true' to skip in dev)
KIRINNET_SKIP_SIG_VERIFY=true

# Next.js frontend (for local dev)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
